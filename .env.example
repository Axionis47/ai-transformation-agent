# =============================================================================
# AI Transformation Discovery Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values
# NEVER commit .env to git — it contains secrets

# -----------------------------------------------------------------------------
# Model Provider — Vertex AI is primary
# -----------------------------------------------------------------------------
MODEL_PROVIDER=vertex                    # vertex | ollama | anthropic
VERTEX_MODEL=gemini-2.5-pro             # Consultant agent
VERTEX_FAST_MODEL=gemini-2.5-flash      # Report writer (faster, cheaper)
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Fallback only — used when Vertex is unavailable
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:72b

# -----------------------------------------------------------------------------
# GCP Authentication
# -----------------------------------------------------------------------------
# Local development: path to service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Cloud Run: uses Workload Identity automatically (no config needed)

# -----------------------------------------------------------------------------
# API Keys — NEVER commit real values
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...            # Evals judge only (not pipeline)

# Optional: protect POST /v1/analyze with a static bearer token.
# Leave unset (or empty) for open access — required for local dev and demos.
# API_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Vector Store
# -----------------------------------------------------------------------------
VECTOR_STORE=chroma                     # chroma | pinecone
CHROMA_PERSIST_DIR=./rag/store          # Local persistence path

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Eval Thresholds
# -----------------------------------------------------------------------------
EVAL_PASS_THRESHOLD=3.8
COST_ALERT_USD=0.12
CONTEXT_WARN_PCT=70

# -----------------------------------------------------------------------------
# Deploy
# -----------------------------------------------------------------------------
DEPLOY_TARGET=gcp                       # gcp | flyio
